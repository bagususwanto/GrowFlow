# Database Connection (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/growflow?schema=public"

# JWT Configuration (Secrets must be at least 32 characters long)
JWT_ACCESS_SECRET="super-secret-jwt-access-key-minimum-32-chars-long"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key-minimum-32-chars-long"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server Port & Web Client URL
PORT=3000
WEB_URL="http://localhost:3001"

# Environment
NODE_ENV="development"
