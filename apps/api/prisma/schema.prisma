generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique // superadmin | manager | sales | purchasing | finance | warehouse
  permissions Json      @default("[]")
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  users       User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("roles")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")

  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id])

  refreshTokens  RefreshToken[]
  stockMutations StockMutation[]

  createdPurchaseOrders  PurchaseOrder[] @relation("POCreatedBy")
  approvedPurchaseOrders PurchaseOrder[] @relation("POApprovedBy")
  createdGoodsReceipts   GoodsReceipt[]  @relation("GRNCreatedBy")
  createdSalesOrders     SalesOrder[]    @relation("SOCreatedBy")
  confirmedSalesOrders   SalesOrder[]    @relation("SOConfirmedBy")
  createdDeliveryNotes   DeliveryNote[]  @relation("DNCreatedBy")

  // Phase 5 Accounting Relations
  createdJournalEntries  JournalEntry[]         @relation("JECreatedBy")
  postedJournalEntries   JournalEntry[]         @relation("JEPostedBy")
  receivedVendorInvoices VendorInvoice[]        @relation("VIReceivedBy")
  createdVendorPayments  VendorInvoicePayment[] @relation("VIPreatedBy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([deletedAt, isActive])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash") // bcrypt hash dari token
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

model Warehouse {
  id             String          @id @default(uuid())
  name           String
  address        String?
  isActive       Boolean         @default(true) @map("is_active")
  deletedAt      DateTime?       @map("deleted_at")
  stockBalances  StockBalance[]
  stockMutations StockMutation[]
  goodsReceipts  GoodsReceipt[]
  salesOrders    SalesOrder[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

model Item {
  id                    String                  @id @default(uuid())
  code                  String                  @unique
  name                  String
  unit                  String
  categoryId            String?                 @map("category_id")
  category              CategoryItem?           @relation(fields: [categoryId], references: [id])
  minStock              Int                     @default(0) @map("min_stock")
  isActive              Boolean                 @default(true) @map("is_active")
  deletedAt             DateTime?               @map("deleted_at")
  stockBalances         StockBalance[]
  stockMutations        StockMutation[]
  poLineItems           PurchaseOrderLineItem[]
  grLineItems           GoodsReceiptLineItem[]
  soLineItems           SalesOrderLineItem[]
  dnLineItems           DeliveryNoteLineItem[]
  salesInvoiceLineItems SalesInvoiceLineItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([deletedAt, isActive, categoryId])
  @@map("items")
}

model CategoryItem {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  deletedAt   DateTime? @map("deleted_at")
  items       Item[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("category_items")
}

enum PartnerType {
  SUPPLIER
  CUSTOMER
}

model Partner {
  id               String          @id @default(uuid())
  code             String          @unique
  name             String
  type             PartnerType
  email            String?
  phone            String?
  address          String?
  paymentTermsDays Int?            @default(30) @map("payment_terms_days")
  isActive         Boolean         @default(true) @map("is_active")
  deletedAt        DateTime?       @map("deleted_at")
  purchaseOrders   PurchaseOrder[]
  salesOrders      SalesOrder[]
  salesInvoices    SalesInvoice[]

  // Phase 5 Accounting Relations
  vendorInvoices VendorInvoice[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("partners")
}

model StockBalance {
  id          String    @id @default(uuid())
  qty         Int       @default(0)
  itemId      String    @map("item_id")
  item        Item      @relation(fields: [itemId], references: [id])
  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([itemId, warehouseId])
  @@index([itemId, warehouseId])
  @@map("stock_balances")
}

enum MutationType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

model StockMutation {
  id            String       @id @default(uuid())
  qty           Int
  type          MutationType
  referenceType String?      @map("reference_type")
  referenceId   String?      @map("reference_id")
  note          String?

  itemId      String    @map("item_id")
  item        Item      @relation(fields: [itemId], references: [id])
  warehouseId String    @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  createdById String?   @map("created_by_id")
  createdBy   User?     @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([itemId, warehouseId, createdAt, type])
  @@map("stock_mutations")
}

model DocumentSequence {
  id      String @id @default(uuid())
  type    String
  year    Int
  month   Int
  lastSeq Int    @default(0) @map("last_seq")

  @@unique([type, year, month])
  @@map("document_sequences")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIAL
  DONE
  CANCELLED
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  number      String              @unique // PO-YYYYMM-XXXX
  supplierId  String              @map("supplier_id")
  supplier    Partner             @relation(fields: [supplierId], references: [id])
  status      PurchaseOrderStatus @default(DRAFT)
  note        String?
  totalAmount Decimal             @default(0) @map("total_amount") @db.Decimal(18, 2)
  orderDate   DateTime            @default(now()) @map("order_date")

  createdById  String?   @map("created_by_id")
  createdBy    User?     @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedById String?   @map("approved_by_id")
  approvedBy   User?     @relation("POApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime? @map("approved_at")
  cancelledAt  DateTime? @map("cancelled_at")

  lineItems     PurchaseOrderLineItem[]
  goodsReceipts GoodsReceipt[]

  // Phase 5 Accounting Relations
  vendorInvoices VendorInvoice[]

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, supplierId, createdAt])
  @@map("purchase_orders")
}

model PurchaseOrderLineItem {
  id              String                 @id @default(uuid())
  purchaseOrderId String                 @map("purchase_order_id")
  purchaseOrder   PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id])
  itemId          String                 @map("item_id")
  item            Item                   @relation(fields: [itemId], references: [id])
  qty             Int
  unitPrice       Decimal                @map("unit_price") @db.Decimal(18, 2)
  totalPrice      Decimal                @map("total_price") @db.Decimal(18, 2) // qty * unitPrice
  qtyReceived     Int                    @default(0) @map("qty_received") // tracking GRN
  grLineItems     GoodsReceiptLineItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("purchase_order_line_items")
}

enum GoodsReceiptStatus {
  DRAFT
  CONFIRMED
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  number          String             @unique // GRN-YYYYMM-XXXX
  purchaseOrderId String             @map("purchase_order_id")
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  warehouseId     String             @map("warehouse_id")
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  status          GoodsReceiptStatus @default(DRAFT)
  receivedDate    DateTime           @default(now()) @map("received_date")
  note            String?

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("GRNCreatedBy", fields: [createdById], references: [id])

  lineItems GoodsReceiptLineItem[]

  // Phase 5 Accounting Relations
  vendorInvoice VendorInvoice?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("goods_receipts")
}

model GoodsReceiptLineItem {
  id             String                @id @default(uuid())
  goodsReceiptId String                @map("goods_receipt_id")
  goodsReceipt   GoodsReceipt          @relation(fields: [goodsReceiptId], references: [id])
  poLineItemId   String                @map("po_line_item_id")
  poLineItem     PurchaseOrderLineItem @relation(fields: [poLineItemId], references: [id])
  itemId         String                @map("item_id")
  item           Item                  @relation(fields: [itemId], references: [id])
  qty            Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("goods_receipt_line_items")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIAL
  DONE
  CLOSED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(uuid())
  number      String           @unique // SO-YYYYMM-XXXX
  customerId  String           @map("customer_id")
  customer    Partner          @relation(fields: [customerId], references: [id])
  warehouseId String           @map("warehouse_id")
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  status      SalesOrderStatus @default(DRAFT)
  note        String?
  totalAmount Decimal          @default(0) @map("total_amount") @db.Decimal(18, 2)
  orderDate   DateTime         @default(now()) @map("order_date")

  createdById   String?   @map("created_by_id")
  createdBy     User?     @relation("SOCreatedBy", fields: [createdById], references: [id])
  confirmedById String?   @map("confirmed_by_id")
  confirmedBy   User?     @relation("SOConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt   DateTime? @map("confirmed_at")
  cancelledAt   DateTime? @map("cancelled_at")

  lineItems     SalesOrderLineItem[]
  deliveryNotes DeliveryNote[]
  salesInvoice  SalesInvoice?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, customerId, createdAt])
  @@map("sales_orders")
}

model SalesOrderLineItem {
  id           String                 @id @default(uuid())
  salesOrderId String                 @map("sales_order_id")
  salesOrder   SalesOrder             @relation(fields: [salesOrderId], references: [id])
  itemId       String                 @map("item_id")
  item         Item                   @relation(fields: [itemId], references: [id])
  qty          Int
  unitPrice    Decimal                @map("unit_price") @db.Decimal(18, 2)
  totalPrice   Decimal                @map("total_price") @db.Decimal(18, 2) // qty * unitPrice
  qtyDelivered Int                    @default(0) @map("qty_delivered") // tracking DN
  dnLineItems  DeliveryNoteLineItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sales_order_line_items")
}

enum DeliveryNoteStatus {
  DRAFT
  CONFIRMED
}

model DeliveryNote {
  id           String             @id @default(uuid())
  number       String             @unique // DN-YYYYMM-XXXX
  salesOrderId String             @map("sales_order_id")
  salesOrder   SalesOrder         @relation(fields: [salesOrderId], references: [id])
  status       DeliveryNoteStatus @default(DRAFT)
  deliveryDate DateTime           @default(now()) @map("delivery_date")
  note         String?

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("DNCreatedBy", fields: [createdById], references: [id])

  lineItems DeliveryNoteLineItem[]

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("delivery_notes")
}

model DeliveryNoteLineItem {
  id             String             @id @default(uuid())
  deliveryNoteId String             @map("delivery_note_id")
  deliveryNote   DeliveryNote       @relation(fields: [deliveryNoteId], references: [id])
  soLineItemId   String             @map("so_line_item_id")
  soLineItem     SalesOrderLineItem @relation(fields: [soLineItemId], references: [id])
  itemId         String             @map("item_id")
  item           Item               @relation(fields: [itemId], references: [id])
  qty            Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("delivery_note_line_items")
}

enum SalesInvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  CANCELLED
}

model SalesInvoice {
  id               String             @id @default(uuid())
  number           String             @unique // INV-YYYYMM-XXXX
  salesOrderId     String             @unique @map("sales_order_id")
  salesOrder       SalesOrder         @relation(fields: [salesOrderId], references: [id])
  customerId       String             @map("customer_id")
  customer         Partner            @relation(fields: [customerId], references: [id])
  status           SalesInvoiceStatus @default(DRAFT)
  invoiceDate      DateTime           @default(now()) @map("invoice_date")
  dueDate          DateTime           @map("due_date")
  paymentTermsDays Int                @default(30) @map("payment_terms_days")
  totalAmount      Decimal            @default(0) @map("total_amount") @db.Decimal(18, 2)
  paidAmount       Decimal            @default(0) @map("paid_amount") @db.Decimal(18, 2)
  note             String?
  sentAt           DateTime?          @map("sent_at")

  createdById String? @map("created_by_id")

  lineItems   SalesInvoiceLineItem[]
  payments    SalesInvoicePayment[]
  creditNotes SalesCreditNote[]

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status, customerId, createdAt])
  @@map("sales_invoices")
}

model SalesInvoiceLineItem {
  id             String       @id @default(uuid())
  salesInvoiceId String       @map("sales_invoice_id")
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id])
  soLineItemId   String       @map("so_line_item_id")
  itemId         String       @map("item_id")
  item           Item         @relation(fields: [itemId], references: [id])
  qty            Int
  unitPrice      Decimal      @map("unit_price") @db.Decimal(18, 2)
  totalPrice     Decimal      @map("total_price") @db.Decimal(18, 2) // qty * unitPrice

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sales_invoice_line_items")
}

model SalesInvoicePayment {
  id             String       @id @default(uuid())
  salesInvoiceId String       @map("sales_invoice_id")
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id])
  amount         Decimal      @db.Decimal(18, 2)
  paymentDate    DateTime     @default(now()) @map("payment_date")
  note           String?
  recordedById   String?      @map("recorded_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sales_invoice_payments")
}

enum SalesCreditNoteStatus {
  DRAFT
  APPLIED
  CANCELLED
}

model SalesCreditNote {
  id             String                @id @default(uuid())
  number         String                @unique // CN-YYYYMM-XXXX
  salesInvoiceId String                @map("sales_invoice_id")
  salesInvoice   SalesInvoice          @relation(fields: [salesInvoiceId], references: [id])
  status         SalesCreditNoteStatus @default(DRAFT)
  amount         Decimal               @db.Decimal(18, 2)
  reason         String
  note           String?
  issuedAt       DateTime?             @map("issued_at")
  createdById    String?               @map("created_by_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sales_credit_notes")
}

// ==========================================
// Phase 5 Accounting & Purchase Invoice Models
// ==========================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountCategory {
  CURRENT_ASSET
  FIXED_ASSET
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  EQUITY
  REVENUE
  COGS
  OPERATING_EXPENSE
  OTHER_EXPENSE
  OTHER_INCOME
}

model Account {
  id              String          @id @default(uuid())
  code            String          @unique
  name            String
  type            AccountType
  category        AccountCategory
  parentId        String?         @map("parent_id")
  parent          Account?        @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[]       @relation("AccountHierarchy")
  isSystemAccount Boolean         @default(false) @map("is_system_account")
  isActive        Boolean         @default(true) @map("is_active")
  deletedAt       DateTime?       @map("deleted_at")

  journalLines JournalLine[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("accounts")
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

model JournalEntry {
  id          String             @id @default(uuid())
  number      String             @unique // JE-YYYYMM-XXXX
  entryDate   DateTime           @default(now()) @map("entry_date")
  description String?
  sourceType  String?            @map("source_type") // VENDOR_INVOICE | SALES_INVOICE | VENDOR_PAYMENT | AR_PAYMENT | MANUAL
  sourceId    String?            @map("source_id") // polymorphic relation ID
  status      JournalEntryStatus @default(DRAFT)

  postedAt   DateTime? @map("posted_at")
  postedById String?   @map("posted_by_id")
  postedBy   User?     @relation("JEPostedBy", fields: [postedById], references: [id])

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("JECreatedBy", fields: [createdById], references: [id])

  lines JournalLine[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, entryDate])
  @@map("journal_entries")
}

model JournalLine {
  id             String       @id @default(uuid())
  journalEntryId String       @map("journal_entry_id")
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String       @map("account_id")
  account        Account      @relation(fields: [accountId], references: [id])
  debit          Decimal      @default(0) @db.Decimal(18, 2)
  credit         Decimal      @default(0) @db.Decimal(18, 2)
  description    String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("journal_lines")
}

enum VendorInvoiceStatus {
  DRAFT
  RECEIVED
  PARTIAL
  PAID
  CANCELLED
}

model VendorInvoice {
  id               String              @id @default(uuid())
  number           String              @unique // BILL-YYYYMM-XXXX
  goodsReceiptId   String              @unique @map("goods_receipt_id")
  goodsReceipt     GoodsReceipt        @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrderId  String              @map("purchase_order_id")
  purchaseOrder    PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id])
  supplierId       String              @map("supplier_id")
  supplier         Partner             @relation(fields: [supplierId], references: [id])
  status           VendorInvoiceStatus @default(DRAFT)
  invoiceDate      DateTime            @default(now()) @map("invoice_date")
  dueDate          DateTime            @map("due_date")
  paymentTermsDays Int                 @default(30) @map("payment_terms_days")
  totalAmount      Decimal             @default(0) @map("total_amount") @db.Decimal(18, 2)
  paidAmount       Decimal             @default(0) @map("paid_amount") @db.Decimal(18, 2)
  note             String?

  receivedAt   DateTime? @map("received_at")
  receivedById String?   @map("received_by_id")
  receivedBy   User?     @relation("VIReceivedBy", fields: [receivedById], references: [id])

  createdById String? @map("created_by_id")

  payments  VendorInvoicePayment[]
  deletedAt DateTime?              @map("deleted_at")
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  @@index([status, supplierId, createdAt])
  @@map("vendor_invoices")
}

model VendorInvoicePayment {
  id              String        @id @default(uuid())
  vendorInvoiceId String        @map("vendor_invoice_id")
  vendorInvoice   VendorInvoice @relation(fields: [vendorInvoiceId], references: [id])
  amount          Decimal       @db.Decimal(18, 2)
  paymentDate     DateTime      @default(now()) @map("payment_date")
  note            String?
  recordedById    String?       @map("recorded_by_id")
  recordedBy      User?         @relation("VIPreatedBy", fields: [recordedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vendor_invoice_payments")
}

model AccountingSettings {
  id                 String   @id @default("default")
  apAccountId        String   @map("ap_account_id")
  arAccountId        String   @map("ar_account_id")
  cashAccountId      String   @map("cash_account_id")
  inventoryAccountId String   @map("inventory_account_id")
  cogsAccountId      String   @map("cogs_account_id")
  revenueAccountId   String   @map("revenue_account_id")
  purchaseAccountId  String   @map("purchase_account_id")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("accounting_settings")
}
